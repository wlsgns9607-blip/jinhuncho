rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (optional for students)
    //   - displayName: string
    //   - role: string (student, teacher) (required)
    //   - className: string (required for students)
    //   - studentNumber: string (required for students)
    //   - badges: list
    //   - createdAt: timestamp
    //
    // Collection: logs
    // Document ID: {logId}
    // Fields:
    //   - studentId: string (required)
    //   - studentName: string
    //   - className: string
    //   - studentNumber: string
    //   - title: string (required)
    //   - content: string (required)
    //   - imageUrl: string
    //   - aiFeedback: string
    //   - createdAt: timestamp
    //
    // Collection: classSettings
    // Document ID: {className}
    // Fields:
    //   - className: string (required)
    //   - teacherId: string (required)
    //   - enabledBadges: list
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "wlsgns9607@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'displayName', 'role', 'className', 'studentNumber', 'badges', 'createdAt']) &&
             data.uid is string &&
             data.role in ['student', 'teacher'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isTeacher());
      allow delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
    }

    match /classSettings/{className} {
      allow read: if isAuthenticated();
      allow create, update: if isTeacher();
    }
  }
}
